# Runtime
APP_ENV=development
API_HOST=127.0.0.1
API_PORT=8000
CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Storage
DATABASE_URL=sqlite:///data/agent-business.sqlite3
UPLOAD_DIR=data/uploads

# OpenAI-compatible model configuration
OPENAI_API_KEY=replace-with-your-local-or-provider-key
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4.1-mini
OPENAI_TIMEOUT_SECONDS=30
OPENAI_MAX_RETRIES=2

# Local testing and demo mode
LLM_USAGE_PROVIDER=local
LLM_USAGE_MODEL=local-estimator
LLM_ESTIMATION_ONLY=true
ENABLE_REAL_PLATFORM_ADAPTERS=false
